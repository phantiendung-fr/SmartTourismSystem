# ============================================================
# Du Lịch Thông Minh Việt Nam - Environment Variables
# Copy file này thành .env và điền thông tin thực
# ============================================================

# Supabase PostgreSQL connection string
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=
# Bật SQL logging (chỉ dùng khi debug)
DB_ECHO=false

# JWT Secret (dùng cho FastAPI auth)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Gemini AI API Key - dùng để xác thực ảnh nhiệm vụ
# Lấy từ: https://aistudio.google.com/apikey
GEMINI_API_KEY=
REDIS_URL=

# Runtime / HTTP settings
ENVIRONMENT=development
REQUIRE_HTTPS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/health,/docs,/openapi.json
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://localhost,capacitor://localhost
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0
OSRM_BASE_URL=https://router.project-osrm.org
AVG_CITY_SPEED_KMH=40.0
